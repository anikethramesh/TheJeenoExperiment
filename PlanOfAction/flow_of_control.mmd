config:
  layout: elk
---
flowchart TD

  Start["Operator utterance"]
  Station["OperatorStation<br>wrap as CorticalEnvelope"]
  SchemaIn["Schema gate<br>validate typed input"]
  Intent["Cortex<br>compile + verify OperatorIntent"]
  Plan["Cortex<br>build RequestPlan"]
  Snapshot["KnowledgeBase<br>claim/procedure snapshot"]
  Ready["ReadinessGraph<br>contracts + claims + authority"]
  Gate["ApprovedCommand"]

  Start --> Station --> SchemaIn --> Intent --> Plan
  Plan --> Ready
  Snapshot --> Ready
  Ready --> Gate

  Gate -->|ask / clarify / refuse / answer| Result["CommandResult<br>with provenance"]
  Result --> End["Await next steering"]

  Gate -->|needs evidence| EvidenceMsg["EvidenceFrame"]
  EvidenceMsg --> Sense["Sense<br>architecture WHAT"]
  Sense --> SenseHow["SubstrateAdapter<br>sensing HOW"]
  SenseHow --> Observation["ObservationClaim<br>source + confidence + freshness"]
  Observation --> KnowledgeWrite["KnowledgeBase<br>record claim/provenance"]
  KnowledgeWrite --> Snapshot

  Gate -->|memory update| MemoryTicket["MemoryWriteTicket"]
  MemoryTicket --> OperatorClaim["KnowledgeBase<br>record operator claim/procedure"]
  OperatorClaim --> Snapshot

  Gate -->|task executable| ExecTicket["ExecutionTicket"]
  ExecTicket --> Spine["Spine<br>ExecutionContract"]
  Spine --> ActionHow["SubstrateAdapter<br>action/planner/controller HOW"]
  ActionHow --> ExecClaim["ExecutionClaim<br>result + provenance"]
  ExecClaim --> KnowledgeWrite

  Gate -->|explicit motor| MotorTicket["RawMotorTicket"]
  MotorTicket --> Spine
