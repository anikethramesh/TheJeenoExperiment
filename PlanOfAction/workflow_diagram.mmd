---
config:
  layout: elk
---
flowchart LR

  OP["OperatorStation<br>operator I/O + session"]
  MSG["Typed Message Gate<br>schemas only"]

  subgraph RUN["Runtime package"]
    CTX["OperationalContext<br>WHERE / MEANING"]
    SUB["SubstrateAdapter<br>concrete HOW bindings"]
  end

  REG["CapabilityRegistry<br>contracts + context task families"]
  FP["Context fingerprint<br>cache / reuse boundary"]
  SLICE["Compact context slice<br>LLM only when needed"]
  TEST["Phase 11B hostile eval ladder<br>same flow under paraphrases"]

  subgraph ARCH["JEENOM WHAT"]
    CX["Cortex<br>intent, plan, repair, synthesize, ask"]
    MC["MissionContract / MissionExecutionPlan<br>compound mission lineage"]
    RG["ReadinessGraph<br>execute / ask / refuse / gather evidence"]
    KB["KnowledgeBase<br>claims + procedures + provenance"]
    SE["Sense<br>evidence requests -> observation claims"]
    SP["Spine<br>execution contracts -> execution claims"]
  end

  CTX --> REG
  SUB --> REG
  CTX --> FP
  SUB --> FP
  CTX --> SLICE

  OP -->|CorticalEnvelope| MSG
  MSG -->|OperatorIntent / steering| CX
  SLICE -. "only for compile / repair / synthesis" .-> CX
  CX -->|MissionContract when compound| MC
  CX -->|RequestPlan when simple| RG
  MC -->|RequestPlan + provenance| RG
  REG --> RG
  FP --> RG
  KB -->|claim/procedure snapshot| RG
  RG -->|ApprovedCommand + verdict| MSG
  MSG -->|CommandResult / clarification| OP

  RG -->|EvidenceFrame| MSG
  MSG --> SE
  SE -->|sense HOW| SUB
  SUB -->|observation result| SE
  SE -->|ObservationClaim| MSG
  MSG --> KB

  RG -->|ExecutionTicket + mission lineage + ExecutionContract| MSG
  MSG --> SP
  SP -->|action HOW| SUB
  SUB -->|execution result| SP
  SP -->|ExecutionClaim| MSG
  MSG --> KB

  RG -->|MemoryWriteTicket| MSG
  MSG --> KB

  KB -->|updated snapshot| CX

  TEST -. "low-level Sense paraphrases" .-> SE
  TEST -. "low-level Spine paraphrases" .-> SP
  TEST -. "named procedures + compound missions" .-> CX
  TEST -. "conditional evidence before actuation" .-> RG
